rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId
    // Fields: id, name, tagline, image, accentColor, description, story, highlights, details, usage, gallery, price, category, stock, variants, isNew
    //
    // Collection: orders
    // Document ID: orderId
    // Fields: id, items, total, status, customer, deliveryType, paymentMethod, createdAt
    //
    // Collection: coupons
    // Document ID: couponCode
    // Fields: code, discountPercent, isActive
    //
    // Collection: users
    // Document ID: userId
    // Fields: uid, email, role
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "valuemoney77@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProduct(data) {
      return data.id is string && data.name is string && data.price is number && data.category is string && data.stock is number;
    }

    function isValidOrder(data) {
      return data.id is string && data.items is list && data.total is number && data.status in ['pending', 'confirmed', 'shipped', 'out-for-delivery', 'delivered'];
    }

    function isValidCoupon(data) {
      return data.code is string && data.discountPercent is number && data.isActive is bool;
    }

    function isValidUser(data) {
      return data.uid is string && data.email is string && data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true; // Allow anyone to place an order
      allow update, delete: if isAdmin();
    }

    match /coupons/{couponCode} {
      allow read: if true; // Allow anyone to check coupons
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAdmin();
    }
  }
}
